generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  logoUrl     String?
  status      String   @default("Waiting to Start")
  tags        String   @default("")
  figmaLink   String?
  links       String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("To Do")
  priority    String    @default("Medium")
  dueDate     DateTime?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projectId  String
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   TeamMember? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

model ResourceFolder {
  id        String             @id @default(cuid())
  name      String
  icon      String?
  position  Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  documents ResourceDocument[]
}

model ResourceDocument {
  id        String         @id @default(cuid())
  title     String
  content   String?
  position  Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  folderId String
  folder   ResourceFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
}

model AdminTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("To Do")
  priority    String   @default("Medium")
  position    Int      @default(0)
  createdAt   DateTime @default(now())
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  email     String?
  color     String   @default("#6366f1")
  avatarUrl String?
  createdAt DateTime @default(now())
  tasks     Task[]
}
